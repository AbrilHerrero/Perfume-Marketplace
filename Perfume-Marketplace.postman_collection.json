{
	"info": {
		"name": "Perfume Marketplace",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080"
		},
		{
			"key": "access_token",
			"value": ""
		},
		{
			"key": "admin_user_id",
			"value": "1"
		},
		{
			"key": "sample_id",
			"value": "1"
		},
		{
			"key": "seller_id",
			"value": "1"
		},
		{
			"key": "perfume_id",
			"value": "1"
		},
		{
			"key": "address_id",
			"value": "1"
		},
		{
			"key": "cart_item_id",
			"value": "1"
		},
		{
			"key": "order_id",
			"value": "1"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register (BUYER)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"    pm.test('Token saved', function () {",
									"        pm.expect(json.access_token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test Buyer\",\n    \"email\": \"buyer@test.com\",\n    \"password\": \"123456\",\n    \"telephone\": \"1122334455\",\n    \"role\": \"BUYER\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						}
					}
				},
				{
					"name": "Register (SELLER)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"    pm.test('Token saved', function () {",
									"        pm.expect(json.access_token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test Seller\",\n    \"email\": \"seller@test.com\",\n    \"password\": \"123456\",\n    \"telephone\": \"1155667788\",\n    \"role\": \"SELLER\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						}
					}
				},
				{
					"name": "Register (ADMIN)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"    pm.test('Token saved', function () {",
									"        pm.expect(json.access_token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test Admin\",\n    \"email\": \"admin@test.com\",\n    \"password\": \"123456\",\n    \"telephone\": \"1199887766\",\n    \"role\": \"ADMIN\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						}
					}
				},
				{
					"name": "Authenticate (Login)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"    pm.test('Token saved', function () {",
									"        pm.expect(json.access_token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"buyer@test.com\",\n    \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/authenticate",
							"host": ["{{base_url}}"],
							"path": ["auth", "authenticate"]
						}
					}
				}
			]
		},
		{
			"name": "Admin",
			"description": "Requires ROLE_ADMIN. Use collection Bearer auth: run **Auth → Register (ADMIN)** or login as admin so `access_token` is set. Most calls need no body. Change `admin_user_id` for get/delete/reactivate by id. Filtered user lists: active, inactive, active buyers, active sellers.",
			"item": [
				{
					"name": "Hi",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/admin/hi",
							"host": ["{{base_url}}"],
							"path": ["admin", "hi"]
						},
						"description": "Smoke test. Response: plain text, e.g. `Hi, Test Admin`."
					}
				},
				{
					"name": "List all users",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/admin/users",
							"host": ["{{base_url}}"],
							"path": ["admin", "users"]
						}
					}
				},
				{
					"name": "List active users",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/admin/users/active",
							"host": ["{{base_url}}"],
							"path": ["admin", "users", "active"]
						},
						"description": "All users with `active: true` (any role)."
					}
				},
				{
					"name": "List inactive users",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/admin/users/inactive",
							"host": ["{{base_url}}"],
							"path": ["admin", "users", "inactive"]
						},
						"description": "All users with `active: false`."
					}
				},
				{
					"name": "List active buyers",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/admin/users/buyers/active",
							"host": ["{{base_url}}"],
							"path": ["admin", "users", "buyers", "active"]
						},
						"description": "Users with role BUYER and `active: true`."
					}
				},
				{
					"name": "List active sellers",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/admin/users/sellers/active",
							"host": ["{{base_url}}"],
							"path": ["admin", "users", "sellers", "active"]
						},
						"description": "Users with role SELLER and `active: true`."
					}
				},
				{
					"name": "Get user by id",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/admin/users/{{admin_user_id}}",
							"host": ["{{base_url}}"],
							"path": ["admin", "users", "{{admin_user_id}}"]
						}
					}
				},
				{
					"name": "Delete user by id (soft delete)",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{base_url}}/admin/users/{{admin_user_id}}",
							"host": ["{{base_url}}"],
							"path": ["admin", "users", "{{admin_user_id}}"]
						},
						"description": "No body. Sets user `active` to false. Edit `admin_user_id` in collection variables (not the admin’s own id if you still need that session)."
					}
				},
				{
					"name": "Reactivate user by id",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"url": {
							"raw": "{{base_url}}/admin/users/{{admin_user_id}}",
							"host": ["{{base_url}}"],
							"path": ["admin", "users", "{{admin_user_id}}"]
						},
						"description": "No body. Sets user `active` to true. May return error if user is already active (`UserAlreadyActivatedException`). Uses Bearer token explicitly (same as collection auth)."
					}
				}
			]
		},
		{
			"name": "Perfume",
			"item": [
				{
					"name": "Get All Perfumes",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/perfume/all",
							"host": ["{{base_url}}"],
							"path": ["perfume", "all"]
						}
					}
				},
				{
					"name": "Create Perfume (ADMIN/SELLER only)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Sauvage\",\n    \"brand\": \"Dior\",\n    \"releaseYear\": 2015,\n    \"imageUrl\": \"https://example.com/sauvage.jpg\",\n    \"gender\": \"Male\",\n    \"sillage\": \"Strong\",\n    \"confidence\": \"High\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/perfume",
							"host": ["{{base_url}}"],
							"path": ["perfume"]
						}
					}
				},
				{
					"name": "Modify Perfume (ADMIN/SELLER only)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Sauvage EDP\",\n    \"brand\": \"Dior\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/perfume/1",
							"host": ["{{base_url}}"],
							"path": ["perfume", "1"]
						}
					}
				},
				{
					"name": "Delete Perfume (ADMIN/SELLER only)",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{base_url}}/perfume/1",
							"host": ["{{base_url}}"],
							"path": ["perfume", "1"]
						}
					}
				}
			]
		},
		{
			"name": "User",
			"item": [
				{
					"name": "Update Password",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"password\": \"newPassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/user/updatePassword",
							"host": ["{{base_url}}"],
							"path": ["user", "updatePassword"]
						},
						"description": "Authenticated user only. JWT identifies the account; body is only the new password."
					}
				},
				{
					"name": "Get current profile (me)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/user/me",
							"host": ["{{base_url}}"],
							"path": ["user", "me"]
						},
						"description": "Returns the authenticated user's profile (id, name, surname, email, telephone, registerDate, active, role). Requires Bearer token (collection auth)."
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Juan\",\n    \"surname\": \"Pérez\",\n    \"telephone\": \"1122334455\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/user/updateUser",
							"host": ["{{base_url}}"],
							"path": ["user", "updateUser"]
						},
						"description": "All fields optional in the API (partial update); send only what you want to change."
					}
				},
				{
					"name": "Delete User (soft delete)",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/user/deleteUser",
							"host": ["{{base_url}}"],
							"path": ["user", "deleteUser"]
						},
						"description": "No body. Requires Bearer token."
					}
				}
			]
		},
		{
			"name": "Sample",
			"description": "All routes require authentication (Bearer). GET: any authenticated user. POST/PUT/PATCH: SELLER (POST and PUT require the full sample body: price, stock, volumeMl, description, imageUrl, perfumeId; PATCH /{id}/stock updates only stock). DELETE: ADMIN or SELLER. Set `seller_id` and `perfume_id` to existing user/perfume IDs in your DB.",
			"item": [
				{
					"name": "Get all samples",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/sample/all",
							"host": ["{{base_url}}"],
							"path": ["sample", "all"]
						},
						"description": "Returns active samples only."
					}
				},
				{
					"name": "Get samples by seller id",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/sample/seller/{{seller_id}}",
							"host": ["{{base_url}}"],
							"path": ["sample", "seller", "{{seller_id}}"]
						},
						"description": "Active samples for the given seller. May return 204 No Content if empty."
					}
				},
				{
					"name": "Get samples by perfume id",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/sample/perfume/{{perfume_id}}",
							"host": ["{{base_url}}"],
							"path": ["sample", "perfume", "{{perfume_id}}"]
						},
						"description": "Active samples for the given perfume. 204 No Content if empty. 404 if the perfume does not exist."
					}
				},
				{
					"name": "Get sample by id",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/sample/{{sample_id}}",
							"host": ["{{base_url}}"],
							"path": ["sample", "{{sample_id}}"]
						},
						"description": "404 if not found or soft-deleted (inactive)."
					}
				},
				{
					"name": "Create sample (SELLER)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"volumeMl\": 5,\n    \"price\": 9.99,\n    \"stock\": 10,\n    \"description\": \"5ml sample\",\n    \"imageUrl\": \"https://example.com/sample.jpg\",\n    \"perfumeId\": {{perfume_id}}\n}"
						},
						"url": {
							"raw": "{{base_url}}/sample",
							"host": ["{{base_url}}"],
							"path": ["sample"]
						},
						"description": "Returns 201 Created with Location header. Body must include all fields: price, stock, volumeMl, description, imageUrl, perfumeId (400 if incomplete). Seller is taken from the JWT (Bearer); do not send sellerId in the body."
					}
				},
				{
					"name": "Update sample (SELLER)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"volumeMl\": 5,\n    \"price\": 12.50,\n    \"stock\": 8,\n    \"description\": \"Updated description\",\n    \"imageUrl\": \"https://example.com/sample.jpg\",\n    \"perfumeId\": {{perfume_id}}\n}"
						},
						"url": {
							"raw": "{{base_url}}/sample/{{sample_id}}",
							"host": ["{{base_url}}"],
							"path": ["sample", "{{sample_id}}"]
						},
						"description": "PUT replaces the sample with a full resource: send price, stock, volumeMl, description, imageUrl, and perfumeId (all required). 400 if any field is missing or blank. Requires Bearer (SELLER). You can only update samples you own (403 otherwise)."
					}
				},
				{
					"name": "Update sample stock (SELLER)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"stock\": 15\n}"
						},
						"url": {
							"raw": "{{base_url}}/sample/{{sample_id}}/stock",
							"host": ["{{base_url}}"],
							"path": ["sample", "{{sample_id}}", "stock"]
						},
						"description": "Updates only the stock of a sample. Requires Bearer (SELLER) and ownership (403 otherwise). Body: { \"stock\": >= 0 }. 400 if missing or negative."
					}
				},
				{
					"name": "Delete sample — soft delete (ADMIN/SELLER)",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{base_url}}/sample/{{sample_id}}",
							"host": ["{{base_url}}"],
							"path": ["sample", "{{sample_id}}"]
						},
						"description": "Sets sample inactive. 204 No Content on success. SELLER may only delete their own samples; ADMIN may delete any."
					}
				}
			]
		},
		{
			"name": "Cart",
			"description": "Base **`/cart`**. **Bearer required.** All routes require **`ROLE_BUYER`** (use **Auth → Register (BUYER)** or login as buyer). Use **`{{sample_id}}`** for an existing active sample when adding lines. Set **`{{cart_item_id}}`** from **Add cart item** (test script saves `id` on 201) or from **Get cart** -> `items[].id`.",
			"item": [
				{
					"name": "Get cart",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/cart",
							"host": ["{{base_url}}"],
							"path": ["cart"]
						},
						"description": "**200** + `CartResponse` (`id`, `items`, `totalPrice`, `createdAt`, `updatedAt`). Pure read: if the buyer has **no cart row yet**, a synthetic empty response is returned (`items: []`, `totalPrice: 0`, without `id`/`createdAt`/`updatedAt`) and **nothing is persisted**. The cart row is created lazily on the first **POST /cart/items**."
					}
				},
				{
					"name": "Get cart item by id",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/cart/items/{{cart_item_id}}",
							"host": ["{{base_url}}"],
							"path": ["cart", "items", "{{cart_item_id}}"]
						},
						"description": "**200** + `CartItemResponse` (`id`, `quantity`, `addedAt`, `sampleId`). **404** if the line is not in your cart."
					}
				},
				{
					"name": "Add cart item",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    if (json && json.id != null) {",
									"        pm.collectionVariables.set('cart_item_id', String(json.id));",
									"    }",
									"    pm.test('Cart item id saved', function () {",
									"        pm.expect(json.id).to.be.a('number');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sampleId\": {{sample_id}},\n    \"quantity\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/cart/items",
							"host": ["{{base_url}}"],
							"path": ["cart", "items"]
						},
						"description": "**201 Created** + `CartItemResponse`; `Location: /cart/items/{id}`. Body: `sampleId` (required), `quantity` (required, >= 1). Duplicate `sampleId` merges quantities on the server."
					}
				},
				{
					"name": "Update cart item quantity",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"quantity\": 2\n}"
						},
						"url": {
							"raw": "{{base_url}}/cart/items/{{cart_item_id}}",
							"host": ["{{base_url}}"],
							"path": ["cart", "items", "{{cart_item_id}}"]
						},
						"description": "**200 OK** + `CartItemResponse` with the updated line (`id`, `quantity`, `addedAt`, `sampleId`). Body: `quantity` (required, >= 1). **404** `CartItemNotFoundException` if the line is not yours. **404** `SampleNotFoundException` if the linked sample was **soft-deleted / inactive** after it was added (same rule as add: you cannot change quantity for inactive samples)."
					}
				},
				{
					"name": "Remove cart item",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{base_url}}/cart/items/{{cart_item_id}}",
							"host": ["{{base_url}}"],
							"path": ["cart", "items", "{{cart_item_id}}"]
						},
